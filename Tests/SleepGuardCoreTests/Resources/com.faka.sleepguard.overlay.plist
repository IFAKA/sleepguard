<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "https://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.faka.sleepguard.overlay</string>
	<key>ProgramArguments</key>
	<array>
		<string>__SLEEPGUARD_OVERLAY_EXECUTABLE__</string>
		<string>--config</string>
		<string>__SLEEPGUARD_CONFIG_PATH__</string>
	</array>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>20</integer>
		<key>Minute</key>
		<integer>45</integer>
	</dict>
	<key>ProcessType</key>
	<string>Interactive</string>
</dict>
</plist>
